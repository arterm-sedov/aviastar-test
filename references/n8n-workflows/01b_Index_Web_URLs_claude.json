      ],
      "typeVersion": 1,
      "parameters": {
        "model": "text-embedding-3-small",
        "options": {}
      }
    },
    {
      "id": "31aa0026-c47b-4d41-8916-f2c857f07276",
      "name": "✅ Web Indexing Done",
      "type": "n8n-nodes-base.set",
      "position": [
        2160,
        100
      ],
      "typeVersion": 3.4,
      "parameters": {
        "assignments": {
          "assignments": [
