        "options": {}
      }
    },
    {
      "id": "2dd5f1eb-b968-40dc-83a3-35b8f7a1019f",
      "name": "📎 Prepare Metadata",
      "type": "n8n-nodes-base.code",
      "position": [
        1440,
        300
      ],
      "typeVersion": 2,
      "parameters": {
        "jsCode": "\n// Grab metadata from the file list item (accessible from loop context)\n// The Google Drive download replaces JSON, so we re-read from loop node\nconst loopItems = $('Loop Over Files').all();\nconst fileItem = loopItems[0]; // current batch item\nconst file = fileItem.json.file || {};\n\nconst fileName    = file.name    || 'unknown_document.pdf';\nconst fileSection = file.section || 'Общий документ';\nconst fileDate    = file.date    || new Date().toISOString().split('T')[0];\n\n// Pass binary data through + metadata as JSON fields\nreturn [{\n  json: {\n    file_name:    fileName,\n    file_section: fileSection,\n    file_date:    fileDate,\n    source:       'google_drive'\n  },\n  binary: $input.first().binary   // preserve the downloaded PDF binary\n}];\n"
      }
    },
    {
      "id": "0a615ac1-a42d-4656-9493-40f336cbaf49",
      "name": "📥 Insert to Supabase",
      "type": "@n8n/n8n-nodes-langchain.vectorStoreSupabase",
      "position": [
        1700,
        300
      ],
      "typeVersion": 1,
      "parameters": {
        "mode": "insert",
        "tableName": {
          "__rl": true,
          "mode": "list",
          "value": "documents",
          "cachedResultName": "documents"
        },
        "embeddingBatchSize": 30,
        "options": {}
      }
    },
    {
      "id": "e5d861e5-0da3-4a70-9665-975c935fa62d",
      "name": "📄 PDF Loader + Metadata",
      "type": "@n8n/n8n-nodes-langchain.documentDefaultDataLoader",
      "position": [
        1500,
        520
      ],
      "typeVersion": 1,
      "parameters": {
        "dataType": "binary",
        "loader": "pdfLoader",
        "textSplittingMode": "custom",
        "options": {
          "metadata": {
            "values": [
              {
                "name": "file",
                "value": "={{ $json.file_name }}"
              },
              {
                "name": "section",
                "value": "={{ $json.file_section }}"
              },
              {
                "name": "date",
                "value": "={{ $json.file_date }}"
              },
              {
                "name": "source",
                "value": "google_drive"
              }
            ]
          }
        }
      }
    },
