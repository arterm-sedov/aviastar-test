      "name": "Google Drive Download",
      "type": "n8n-nodes-base.googleDrive",
      "position": [
        1200,
        300
      ],
      "typeVersion": 3,
      "parameters": {
        "operation": "download",
        "fileId": {
          "__rl": true,
          "mode": "id",
