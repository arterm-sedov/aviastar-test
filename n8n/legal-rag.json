    {
      "parameters": {
        "promptType": "define",
        "text": "=<role>\nYou are a strict quality evaluator for assistant's RAG answers in a legal/HR department.\n</role>\n\n<task>\nEvaluate the answer below against the user question. Output valid JSON per the authorative schema.\n\nScoring criteria:\n\nScores range: 0.0-1.0\n\n1. Source citations: Does the answer cite specific documents, laws, articles? If answer cites specific laws (ТК РФ, статьи), set `true`. Otherwise set `false`.\n2. Relevance: Is the answer relevant to the question?\n3. Specificity: Detailed and specific, or vague?\n4. Completeness: Fully addresses the question?\n5. Confidence: Is the answer really based on the ground truth and valid?\n\n</task>\n\nUser question:\n{{ $('Chat unify').item.json.chatInput }}\nUser question category:\n{{ $('Category human-readable').item.json.category }}\nAnswer to evaluate:\n{{ $json.output }}\n\n<question_classification>\nThe assistant must answer only legal and HR-related questions.\nThe assistant must reject any other topics immediately.\n</question_classification>",
        "hasOutputParser": true
      },
      "id": "fc71d94a-a096-4727-b4cf-0aa976d2d0bb",
      "name": "LLM Answer Judge",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        -2304,
        1712
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputItem = $input.all()[0].json;\nconst judgeScores = inputItem.output || {};\nconst hasCitations = judgeScores.hasCitations === true;\nconst relevance = parseFloat(judgeScores.relevance) || 0;\nconst specificity = parseFloat(judgeScores.specificity) || 0;\nconst completeness = parseFloat(judgeScores.completeness) || 0;\nconst confidence = parseFloat(judgeScores.confidence) || 0;\nconst compositeScore = (relevance + specificity + completeness + confidence) / 4;\nconst pct = (Math.min(Math.max(compositeScore, 0), 1) * 100).toFixed(0);\nconst sessionId = inputItem.sessionId || '';\nconst now = new Date().toLocaleString(\"ru-RU\", { timeZone: \"Europe/Moscow\" });\nconst category = $('Categorize').first().json.output.category || \"general\";\nconst agentOutput = String($('Legal/HR AI Agent').first().json.output || '');\nconst sourceCount = judgeScores.sourceCount;\nconst lowConf = compositeScore < 0.6;\nvar catLabel = \"Общий вопрос\";\nvar disclaimer = \"\";\nif (category === \"hr\") {\n  catLabel = \"Кадровый вопрос\";\n  disclaimer = \"Ответ основан на внутренних HR-документах. Источники имеют приоритет.\";\n} else if (category === \"legal\") {\n  catLabel = \"Юридический вопрос\";\n  disclaimer = \"Данный ответ носит информационный характер. Для финальных документов требуется проверка специалистом.\";\n} else {\n  disclaimer = \"Ответ основан на доступных документах. Первоисточники имеют приоритет.\";\n}\nvar header = \"**Категория:** \" + catLabel;\nheader += \"\\n\\n**Общая уверенность:** \" + pct + \"%\";\nif (!hasCitations) header += \"  (нет источников)\";\nif (lowConf) header += \"  (ниже порога 60%)\";\nheader += \"\\n\\n**Найдено источников:** \" + sourceCount;\nheader += \"\\n\\n**Источники:** \" + (hasCitations ? \"ДА\" : \"НЕТ\");\nheader += \"\\n\\n**Релевантность:** \" + (relevance * 100).toFixed(0) + \"%\";\nheader += \"\\n\\n**Специфичность:** \" + (specificity * 100).toFixed(0) + \"%\";\nheader += \"\\n\\n**Полнота:** \" + (completeness * 100).toFixed(0) + \"%\";\nheader += \"\\n\\n**Достоверность:** \" + (confidence * 100).toFixed(0) + \"%\";\nheader += \"\\n\\n---\\n\\n\";\nvar footer = \"\\n\\n---\\n\\n\";\nif (!hasCitations) {\n  footer += \"**Ответ без источников. Требуется проверка специалистом.**\\n\";\n} else if (lowConf) {\n  footer += \"**Точность ниже порога. Рекомендуется проверка специалистом.**\\n\";\n} else {\n  footer += disclaimer + \"\\n\";\n}\nfooter += now;\nreturn [{ json: { output: header + agentOutput + footer, sessionId: sessionId } }];\n"
      },
      "id": "171c9348-d303-457b-91df-d935c5470dc2",
      "name": "Template Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2016,
        1712
      ]
    },
    {
      "parameters": {
        "schemaType": "manual",
